# Production Environment Variables
# Copy this file to .env.production and fill in your actual values
# NEVER commit .env.production to version control

# Database Configuration
POSTGRES_USER=your_db_user
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=st_pilot_ids_production

# Rails Configuration
# SECRET_KEY_BASE: Run `bin/rails secret` to generate one
SECRET_KEY_BASE=your_secret_key_base_here
# RAILS_MASTER_KEY: Copy from config/master.key (used to decrypt credentials.yml.enc)
RAILS_MASTER_KEY=your_master_key_from_config_master_key
RAILS_MAX_THREADS=5
WEB_CONCURRENCY=2

# Application Port (host port mapped to container port 3000)
PORT=3009

# Docker Image (override to use a specific tag)
# DOCKER_IMAGE=ghcr.io/arya020595/st_pilot_ids:latest
