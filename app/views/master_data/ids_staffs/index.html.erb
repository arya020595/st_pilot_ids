<div id="ids_staffs" class="container-fluid px-4 py-4 ids-staffs-list">
  <div class="ids_staffs_page">
    <h1 class="mb-0">IDS Staff</h1>
    <%= search_form_for @q, url: master_data_ids_staffs_path,
          html: {
            id: 'ids-staff-search-form',
            data: {
              controller: 'search-form',
              action: 'submit->search-form#resetPage'
            }
          } do |f| %>
      <%= hidden_field_tag :per_page, @per_page %>
      <div class="table-responsive ids-staff-table-wrap">
        <table class="table table-hover table-sm mb-0 ids-staff-table">
          <colgroup>
            <col class="ids-staff-id-col" />
            <col />
            <col />
            <col />
          </colgroup>
          <thead class="header-row">
            <tr class="header-row">
              <th><%= sort_link(@q, :code, 'IDS Staff ID') %></th>
              <th><%= sort_link(@q, :fullname, 'Full Name') %></th>
              <th><%= sort_link(@q, :grade, 'Grade') %></th>
              <th><%= sort_link(@q, :division, 'Departement/Unit') %></th>
            </tr>
            <tr class="ids-staff-filter-row">
              <th>
                <%= f.search_field :code_cont,
                      class: 'form-control form-control-sm',
                      placeholder: 'Type ID',
                      data: { action: 'input->search-form#autoSubmit' } %>
              </th>
              <th>
                <%= f.search_field :fullname_cont,
                      class: 'form-control form-control-sm',
                      placeholder: 'Type full name',
                      data: { action: 'input->search-form#autoSubmit' } %>
              </th>
              <th>
                <%= f.search_field :grade_cont,
                      class: 'form-control form-control-sm',
                      placeholder: 'Type grade',
                      data: { action: 'input->search-form#autoSubmit' } %>
              </th>
              <th>
                <%= f.search_field :division_cont,
                      class: 'form-control form-control-sm',
                      placeholder: 'Type department/unit',
                      data: { action: 'input->search-form#autoSubmit' } %>
              </th>
            </tr>
          </thead>
          <tbody id="ids-staffs-table-body">
            <% if @ids_staffs.any? %>
              <% @ids_staffs.each do |ids_staff| %>
                <tr>
                  <td class="ids-staff-id-value"><%= ids_staff.code %></td>
                  <td><%= ids_staff.fullname %></td>
                  <td><%= ids_staff.grade %></td>
                  <td><%= ids_staff.division %></td>
                </tr>
              <% end %>
            <% else %>
              <tr>
                <td colspan="4" class="text-center text-muted py-4">
                  No IDS staff records found.
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% end %>
    <div class="d-flex justify-content-between align-items-center mt-3 flex-wrap gap-2">
      <div class="d-flex align-items-center gap-2 flex-wrap">
        <%= form_with url: master_data_ids_staffs_path, method: :get, local: true, class: 'd-flex align-items-center gap-2' do %>
          <% if params[:q].present? %>
            <% params[:q].each do |key, value| %>
              <% next if value.blank? %>
              <%= hidden_field_tag "q[#{key}]", value %>
            <% end %>
          <% end %>
          <label for="per_page" class="small text-muted">Show</label>
          <%= select_tag :per_page,
                options_for_select([10, 25, 50, 100], @per_page),
                class: 'form-select form-select-sm per-page-control',
                onchange: 'this.form.submit();' %>
          <span class="small text-muted">entries</span>
        <% end %>
        <span class="text-muted small">
          <%== @pagy.info_tag(item_name: 'ids staff') %>
        </span>
      </div>
      <div>
        <%== @pagy.series_nav(:bootstrap) if @pagy.pages > 1 %>
      </div>
    </div>
  </div>
</div>
