<div class="container-fluid px-4 py-4">
  <h1 class="mb-4">BI Dashboard</h1>
  <div class="row g-4 mb-4">
    <div class="col-md-12 text-center">
      <% if ENV["BI_DASHBOARD_URL"].present? %>
        <div class="powerbi-dashboard">
          <iframe title="BI Dashboard"
              width="100%"
              height="550"
              src="<%= ENV["BI_DASHBOARD_URL"] %>"
              frameborder="0"
              allowFullScreen="true">
          </iframe>
        </div>
      <% else %>
        <p class="text-muted">BI Dashboard is not configured. Please set the <code>BI_DASHBOARD_URL</code> environment variable.</p>
      <% end %>
    </div>
  </div>
</div>