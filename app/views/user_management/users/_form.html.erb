<%= form_with(
      model: [:user_management, user],
      data: {
        controller: 'staff-selection',
        'staff-selection-current-user-id-value': user.id
      }
    ) do |form| %>
  <div class="modal-header">
    <h5 class="modal-title">
      <strong><%= user.persisted? ? 'Edit User' : 'Add New User' %></strong>
    </h5>
    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
  </div>

  <div class="modal-body">
    <% if user.errors.any? %>
      <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <h6 class="alert-heading">
          <i class="bi bi-exclamation-triangle-fill"></i>
          <%= pluralize(user.errors.count, "error") %> prohibited this user from being saved:
        </h6>
        <ul class="mb-0 mt-2">
          <% user.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
      </div>
    <% end %>

    <div class="row">
      <div class="col-md-6 mb-3">
        <%= form.label :name, class: "form-label fw-semibold" %>
        <%= form.text_field :name, class: "form-control", placeholder: "Enter full name", required: true, data: { 'staff-selection-target': 'nameField' } %>
      </div>
      <div class="col-md-6 mb-3">
        <%= form.label :email, class: "form-label fw-semibold" %>
        <%= form.email_field :email, class: "form-control", placeholder: "Enter email address", required: true, data: { 'staff-selection-target': 'emailField' } %>
      </div>
    </div>

    <div class="mb-3">
      <%= form.label :role_id, "Role", class: "form-label fw-semibold" %>
      <%= form.collection_select :role_id, Role.order(:name), :id, :name, { include_blank: "Select Role" }, { class: "form-select", required: true, data: { 'staff-selection-target': 'roleSelect', action: 'change->staff-selection#roleChanged' } } %>
    </div>

    <div class="mb-3 d-none" data-staff-selection-target="staffContainer">
      <%= form.label :staff_profile_id, 'Staff Name', class: 'form-label fw-semibold' %>
      <%= form.hidden_field :staff_profile_id, data: { 'staff-selection-target': 'staffIdField' } %>
      <div class="position-relative">
        <input type="text"
               class="form-control"
               placeholder="Type to search staff name"
               autocomplete="off"
               value="<%= user.staff_profile&.fullname %>"
               data-staff-selection-target="staffSearchInput"
               data-action="focus->staff-selection#openDropdown input->staff-selection#searchChanged" />
        <div class="staff-search-dropdown d-none" data-staff-selection-target="staffDropdown"></div>
      </div>
    </div>

    <div class="row">
      <div class="col-md-6 mb-3">
        <%= form.label :password, class: "form-label fw-semibold" %>
        <%= form.password_field :password, class: "form-control",
            placeholder: user.persisted? ? "Leave blank to keep current password" : "Enter password",
            required: user.new_record? %>
        <small class="form-text text-muted">
          <% if user.persisted? %>
            Leave blank if you don't want to change the password
          <% else %>
            Minimum 6 characters
          <% end %>
        </small>
      </div>
      <div class="col-md-6 mb-3">
        <%= form.label :password_confirmation, "Confirm Password", class: "form-label fw-semibold" %>
        <%= form.password_field :password_confirmation, class: "form-control",
            placeholder: user.persisted? ? "Leave blank to keep current password" : "Re-enter password",
            required: user.new_record? %>
      </div>
    </div>

    <div class="mb-3">
      <div class="form-check form-switch">
        <%= form.check_box :is_active, class: "form-check-input", role: "switch" %>
        <%= form.label :is_active, "Active Status", class: "form-check-label" %>
        <small class="form-text text-muted d-block">Toggle to set user as active or inactive</small>
      </div>
    </div>
  </div>

  <div class="modal-footer">
    <%= button_tag type: :submit, class: "btn btn-success" do %>
      <i class="bi bi-save-fill text-white me-1"></i>Save
    <% end %>
  </div>
<% end %>
