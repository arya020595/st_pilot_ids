<div id="kpi_assessments" class="kpi-assessment-page">
  <div class="kpi-panel-title">
    KPI Assessment &gt; Edit &gt; <%= @assessment.fullname %>
  </div>

  <div class="kpi-back-link-wrap">
    <%= link_to kpi_assessments_path, class: "kpi-back-link" do %>
      <i class="bi bi-arrow-left me-2"></i>Back to KPI Assessment
    <% end %>
  </div>

  <%= form_with url: kpi_assessment_path(@assessment), method: :patch, local: true, class: "kpi-form" do %>
    <div class="row g-3 mb-3">
      <div class="col-md-6">
        <label class="form-label fw-semibold">Staff Name</label>
        <input type="text" class="form-control" readonly value="<%= @assessment.fullname %>">
      </div>
      <div class="col-md-6">
        <label class="form-label fw-semibold">Position</label>
        <input type="text" class="form-control" readonly value="<%= @assessment.position %>">
      </div>
      <div class="col-md-6">
        <label class="form-label fw-semibold">Reviewed By</label>
        <input type="text" class="form-control" readonly value="<%= @reviewed_by %>">
      </div>
      <div class="col-md-6">
        <label class="form-label fw-semibold">Final Score</label>
        <input type="text"
               class="form-control"
               readonly
               value="<%= @assessment.overall_score.present? ? "#{number_with_precision(@assessment.overall_score, precision: 2)}%" : '---' %>">
      </div>
    </div>

    <div class="kpi-score-shell mt-2"
         data-controller="kpi-tab-total kpi-quantity-form"
         data-kpi-tab-total-quality-value="<%= @quality_overall_total %>"
         data-kpi-tab-total-quantity-value="<%= @quantity_overall_total %>">
      <div class="kpi-score-header-row">
        <h2>Edit Scores</h2>
      </div>

      <div class="kpi-mode-header-row">
        <ul class="nav nav-pills kpi-mode-pills" role="tablist">
          <li class="nav-item" role="presentation">
            <button class="mode-pill active"
                    data-bs-toggle="pill"
                    data-bs-target="#edit-kpi-quantity"
                    data-action="click->kpi-tab-total#showQuantity"
                    type="button"
                    role="tab">Quantity-Based</button>
          </li>
          <li class="nav-item" role="presentation">
            <button class="mode-pill"
                    data-bs-toggle="pill"
                    data-bs-target="#edit-kpi-quality"
                    data-action="click->kpi-tab-total#showQuality"
                    type="button"
                    role="tab">Quality-Based</button>
          </li>
        </ul>

        <div class="kpi-overall-score">Overall Total(%) : <span data-kpi-tab-total-target="totalValue"><%= @quantity_overall_total %></span> / 100</div>
      </div>

      <div class="tab-content">
        <div class="tab-pane fade show active" id="edit-kpi-quantity" role="tabpanel">
          <div class="kpi-section-block mt-2">
            <div class="kpi-section-title">
              <span>Output and Impact Based</span>
              <i class="bi bi-chevron-up"></i>
            </div>

            <table class="table kpi-score-table mb-0">
              <thead>
                <tr>
                  <th>Component of Assessment</th>
                  <th class="text-center">Weight (%)</th>
                  <th class="text-center">Maximum Number (Qty)</th>
                  <th class="text-center">Actual Number (Qty)</th>
                  <th class="text-center">Actual Score (%)</th>
                </tr>
              </thead>
              <tbody>
                <% @quantity_view_rows.each do |row| %>
                  <tr>
                    <td><%= row[:label] %></td>
                    <td class="text-center"><%= row[:weight_percent].to_d %>%</td>
                    <td class="text-center"><%= row[:max_input_percent].to_i %></td>
                    <td>
                      <input type="number"
                             name="<%= row[:field] %>"
                             class="form-control score-input"
                             data-action="input->kpi-quantity-form#scoreChanged"
                             data-weight="<%= row[:weight_percent].to_d %>"
                             data-max-input="<%= row[:max_input_percent].to_d %>"
                             min="0"
                             max="<%= row[:max_input_percent].to_d %>"
                             step="1"
                             value="<%= row[:actual_score].to_i %>"
                             required>
                    </td>
                    <td class="text-center" data-kpi-quantity-form-target="rowScore"><%= row[:weighted_score].to_d %>%</td>
                  </tr>
                <% end %>
                <tr class="kpi-weight-row">
                  <td>Weightage and Score</td>
                  <td class="text-center">100%</td>
                  <td class="text-center">-</td>
                  <td class="text-center">-</td>
                  <td class="text-center" data-kpi-quantity-form-target="sectionScore"><%= @quantity_overall_total %>%</td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>

        <div class="tab-pane fade" id="edit-kpi-quality" role="tabpanel">
          <% @quality_view_sections.each do |section| %>
            <div class="kpi-section-block">
              <div class="kpi-section-title">
                <span><%= section[:title] %></span>
                <i class="bi bi-chevron-up"></i>
              </div>

              <table class="table kpi-score-table mb-0">
                <thead>
                  <tr>
                    <th>Component of Assessment</th>
                    <th class="text-center">Full Score (%)</th>
                    <th class="text-center">Actual Score (%)</th>
                  </tr>
                </thead>
                <tbody>
                  <% section[:rows].each do |row| %>
                    <tr>
                      <td><%= row[:label] %></td>
                      <td class="text-center"><%= row[:full_score].to_d %>%</td>
                      <td>
                        <input type="number"
                               name="<%= row[:field] %>"
                               class="form-control score-input <%= 'is-disabled-by-position' if row[:locked] %>"
                               min="0"
                               max="<%= row[:full_score].to_d %>"
                               step="0.01"
                               value="<%= row[:actual_score].to_d %>"
                               <%= 'readonly' if row[:locked] %>
                               <%= 'required' unless row[:locked] %>>
                      </td>
                    </tr>
                  <% end %>
                  <tr class="kpi-weight-row">
                    <td>Weightage and Score</td>
                    <td class="text-center"><%= section[:section_weight] %>%</td>
                    <td class="text-center"><%= section[:weighted_score] %>%</td>
                  </tr>
                </tbody>
              </table>
            </div>
          <% end %>
        </div>
      </div>

      <div class="kpi-step-actions split">
        <%= link_to kpi_assessments_path, class: "btn btn-kpi-prev" do %>
          <i class="bi bi-arrow-left-short me-1"></i>Cancel
        <% end %>
        <button class="btn btn-kpi-next" type="submit">
          Save
        </button>
      </div>
    </div>
  <% end %>
</div>
