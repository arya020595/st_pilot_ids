<div class="container py-4">
  <%= render "shared/breadcrumb", breadcrumbs: [["Dashboard", dashboard_path], ["Edit Profile", nil]] %>
  <div class="card shadow-sm border-0">
    <div class="card-header bg-white border-bottom py-3">
      <h5 class="mb-0 fw-bold"><i class="bi bi-person-gear me-2"></i>Edit Profile</h5>
    </div>
    <div class="card-body p-4">
      <%= render "devise/shared/error_messages", resource: resource %>
      <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put }) do |f| %>
        <div class="row">
          <div class="col-md-6 mb-3">
            <%= f.label :name, class: "form-label fw-semibold" %>
            <%= f.text_field :name, autofocus: true, class: "form-control", placeholder: "Enter your name" %>
          </div>
          <div class="col-md-6 mb-3">
            <%= f.label :email, class: "form-label fw-semibold" %>
            <%= f.email_field :email, autocomplete: "email", class: "form-control", placeholder: "Enter your email" %>
          </div>
        </div>
        <hr class="my-4">
        <h6 class="fw-bold text-muted mb-3"><i class="bi bi-shield-lock me-1"></i>Change Password</h6>
        <div class="row">
          <div class="col-md-6 mb-3">
            <%= f.label :password, "New Password", class: "form-label fw-semibold" %>
            <%= f.password_field :password, autocomplete: "new-password", class: "form-control", placeholder: "Leave blank to keep current" %>
            <% if @minimum_password_length %>
              <div class="form-text"><%= @minimum_password_length %> characters minimum</div>
            <% end %>
          </div>
          <div class="col-md-6 mb-3">
            <%= f.label :password_confirmation, "Confirm New Password", class: "form-label fw-semibold" %>
            <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "form-control", placeholder: "Confirm new password" %>
          </div>
        </div>
        <div class="row">
          <div class="col-md-6 mb-3">
            <%= f.label :current_password, class: "form-label fw-semibold" %>
            <%= f.password_field :current_password, autocomplete: "current-password", class: "form-control", placeholder: "Enter current password to confirm changes" %>
            <div class="form-text">We need your current password to confirm changes</div>
          </div>
        </div>
        <div class="d-flex gap-2 mt-3">
          <%= f.submit "Update Profile", class: "btn btn-primary" %>
          <%= link_to "Cancel", dashboard_path, class: "btn btn-outline-secondary" %>
        </div>
      <% end %>
    </div>
  </div>
  <div class="card shadow-sm border-0 mt-4 border-danger">
    <div class="card-header bg-white border-bottom py-3">
      <h5 class="mb-0 fw-bold text-danger"><i class="bi bi-exclamation-triangle me-2"></i>Danger Zone</h5>
    </div>
    <div class="card-body p-4">
      <p class="text-muted mb-3">Once you delete your account, there is no going back. Please be certain.</p>
      <%= button_to "Delete My Account", registration_path(resource_name), method: :delete,
          data: { turbo_confirm: "Are you sure you want to delete your account? This action cannot be undone." },
          class: "btn btn-outline-danger" %>
    </div>
  </div>
</div>
